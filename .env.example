# The exact public URL you'll open the app at. Passkeys are bound to it and
# Caddy provisions the HTTPS certificate for it — pick the final hostname
# BEFORE anyone registers.
APP_ORIGIN=https://league.example.com

# TMDB API key (free: https://www.themoviedb.org/settings/api).
# Without it, movie search is unavailable and players use free-text entry.
TMDB_API_KEY=

# The username that gets operator (super-admin) powers when it registers.
OPERATOR_USERNAME=

# Web push (optional). Generate keys with:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Coin rewards (optional; instance-wide, SPEC §15)
#COINS_PARTICIPATION=5
#COINS_FIRST=30
#COINS_SECOND=20
#COINS_THIRD=10
